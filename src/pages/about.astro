---
import Layout from "../components/Layout.astro";
import Heading from "../components/Heading.astro";
import Prose from "../components/Prose.astro";
---

<Layout title="About — Mocalabs" description="About Mocalabs.dev">
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AboutPage",
      name: "About Mocalabs.dev",
      description: "About Mocalabs.dev",
      url: new URL("/about", Astro.site).href,
      isPartOf: {
        "@type": "WebSite",
        name: "Mocalabs",
        url: Astro.site?.href,
      },
    })}
  />
  <section class="about">
    <Heading as="h1">Welcome to Mocalabs!</Heading>
    <Prose>
      <p>
        Hello and welcome to Mocalabs: Blog of Abhilasha Figueroa. This is a
        personal blog that serves three main functions:
      </p>
      <ol>
        <li>
          A place where I can write about my work as a sort of portfolio/landing
          page.
        </li>
        <li>
          A place where I can write about computing topics that I find
          interesting (which will likely be centered around Linux and FOSS).
        </li>
        <li>
          A place for me to occasionally write about music. After all, my life
          as a musician predates my life as a computer nerd by a few years.
        </li>
      </ol>
      <p>
        If you'd like to drop me a message, send me some hate mail, or <a
          href="https://xkcd.com/386/"
          target="_blank">correct me on something where I am wrong</a
        >, you can do so at abhilasha [dot] figueroa [at] protonmail [dot] com.
      </p>
      <aside>
        NOTE: I hate that I feel the need to say this, but here we go:
        <br /><br />
        Everything written here and all content at this domain was written by me and
        exactly NONE of it was generated by an LLM. Yes, I use bullet points and em
        dashes and no, I will not stop using them just because some people think they
        are a "tell" for AI generated text. Punctuation makes text clear and precise
        and you can pry my punctuation marks from my cold dead hands.
      </aside>
    </Prose>
  </section>
</Layout>

<style>
  .about {
    max-width: var(--width-content);
  }
</style>
